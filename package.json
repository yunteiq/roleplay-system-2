{
  "name": "live-npc-roleplay",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Distributed, low-latency live NPC voice roleplay system",
  "scripts": {
    "dev": "concurrently -k -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "node scripts/build-client.mjs --watch",
    "build": "node scripts/build-client.mjs",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nanoid": "^5.1.11",
    "openai": "^6.42.0",
    "selfsigned": "^5.5.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
