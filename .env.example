# ---------------------------------------------------------------------------
# Required: a single OpenAI key runs the whole system (STT, director, dialogue, TTS)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# Optional: unlocks the Gemini director/dialogue options
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8787
HOST=0.0.0.0
# Provide a trusted cert (e.g. mkcert) to avoid browser warnings:
TLS_CERT=
TLS_KEY=
# Escape hatch: serve plain HTTP. Mic then only works on localhost or behind
# an HTTPS-terminating proxy/tunnel.
INSECURE_HTTP=false

# ---------------------------------------------------------------------------
# Models — configurable as "provider:model"
# ---------------------------------------------------------------------------
# STT over the OpenAI Realtime transcription API. Server-VAD models
# (gpt-4o-transcribe, gpt-4o-mini-transcribe) let OpenAI segment turns. Whisper-
# style streaming models (gpt-realtime-whisper) have no server VAD, so the server
# runs its own energy VAD + manual commit (auto-detected from the model name;
# override with STT_SERVER_VAD=true|false).
STT_MODEL=openai:gpt-4o-mini-transcribe
STT_LANGUAGE=en
DIRECTOR_MODEL=openai:gpt-4.1-nano
DIALOGUE_MODEL=openai:gpt-4.1-mini
TTS_MODEL=openai:gpt-4o-mini-tts

# Higher-quality dialogue alternative:
# DIALOGUE_MODEL=openai:gpt-5.4-mini

# Optional Gemini models (require GEMINI_API_KEY). gemini-2.0-flash is retired.
GEMINI_DIRECTOR_MODEL=gemini:gemini-3.1-flash-lite
GEMINI_DIALOGUE_MODEL=gemini:gemini-3.5-flash
GEMINI_THINKING_LEVEL=MINIMAL

# ---------------------------------------------------------------------------
# Conversation
# ---------------------------------------------------------------------------
MAX_NPC_CHAIN=3
BARGE_IN=true

# ---------------------------------------------------------------------------
# VAD (latency-oriented but safe). Increase VAD_SILENCE_MS if it cuts people off.
# ---------------------------------------------------------------------------
VAD_THRESHOLD=0.5
VAD_PREFIX_PADDING_MS=120
VAD_SILENCE_MS=250
# Energy gate (normalized RMS 0..1) for the server-side manual VAD, used only
# when STT has no server VAD (e.g. gpt-realtime-whisper). Raise if noise self-
# triggers; lower if quiet speech isn't picked up.
STT_VAD_ENERGY_THRESHOLD=0.02

# ---------------------------------------------------------------------------
# Audio — one 24 kHz PCM path end to end
# ---------------------------------------------------------------------------
AUDIO_SAMPLE_RATE=24000
MIC_FRAME_MS=20
MIC_FRAME_MS_FALLBACK=40
PLAYBACK_PREFILL_MS=40
PLAYBACK_MAX_BUFFER_MS=120

# ---------------------------------------------------------------------------
# TTS chunking (stable speakable phrases; start before the first full sentence)
# ---------------------------------------------------------------------------
TTS_SEGMENT_MODE=stable_phrase
TTS_FIRST_CHUNK_MIN_WORDS=1
TTS_FIRST_CHUNK_MAX_WORDS=8
TTS_LATER_CHUNK_MAX_WORDS=16
TTS_MAX_WAIT_FOR_FIRST_CHUNK_MS=250
TTS_ALLOW_COMMA_BOUNDARY=true
TTS_ALLOW_DASH_BOUNDARY=true
TTS_APPEND_TRAILING_SPACE=true

# ---------------------------------------------------------------------------
# Speculative low-latency behavior
# ---------------------------------------------------------------------------
SPECULATIVE_DIRECTOR=true
SPECULATIVE_DIALOGUE=true
SPECULATIVE_MIN_WORDS_DIRECTOR=3
SPECULATIVE_MIN_WORDS_DIALOGUE=6
SPECULATIVE_SIMILARITY_THRESHOLD=0.82
